---
layout: base.njk
title: בתי כנסת
description: בתי כנסת ומניינים במעלה עמוס
---
<section class="page-content">
  <div class="container">
    <h1>{{ content.shuls.title }}</h1>
    <p>{{ content.shuls.subtitle }}</p>
    <div class="cards">
      {% for s in content.shuls.items %}
      <article class="shul-card" style="border-right:4px solid {{ s.borderColor }}">
        <i class="bi {{ s.icon }}" style="color:{{ s.iconColor }}" aria-hidden="true"></i>
        <h3>{{ s.name }}</h3>
        <p><strong>נוסח:</strong> {{ s.nosach }}</p>
        {% if s.times %}
          <p><strong>שחרית:</strong> {{ s.times.shacharit }}</p>
          <p><strong>מנחה:</strong> {{ s.times.mincha }}</p>
          <p><strong>ערבית:</strong> {{ s.times.maariv }}</p>
          {% if s.timesStatus == "בבדיקה" %}<small class="verify-badge">זמנים בבדיקה</small>{% endif %}
        {% endif %}
        {% if s.email %}<p><small>{{ s.email }}</small></p>{% endif %}
        {% if s.location %}<p><small>{{ s.location }}</small></p>{% endif %}
        {% if s.note %}<p>{{ s.note }}</p>{% endif %}
      </article>
      {% endfor %}
    </div>
  </div>
</section>
