---
layout: base.njk
title: חינוך
description: מוסדות חינוך במעלה עמוס — חדר לבנים, בית יעקב, גנים, כולל, מתנ"ס
---
<section class="page-content">
  <div class="container">
    <h1>{{ sections.education.title }}</h1>
    <p>{{ sections.education.subtitle }}</p>

    <div class="edu-cards" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px;margin-top:24px">
      {%- for i in sections.education.items %}
      <div class="edu-card" style="background:#fff;padding:20px;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,.06);border-right:4px solid var(--primary)">
        <i class="bi {{ i.icon or 'bi-mortarboard' }}" aria-hidden="true" style="font-size:2rem;color:var(--primary);display:block;margin-bottom:8px"></i>
        <h3 style="color:var(--primary-dark);margin-bottom:8px;font-size:1.15rem">{{ i.name }}</h3>
        <p style="color:var(--text-light);font-size:0.9rem">{{ i.description }}</p>
        {% if i.hours %}<p><strong>שעות:</strong> {{ i.hours }}{% if i.hoursStatus == "בבדיקה" %} <small class="verify-badge">בבדיקה</small>{% endif %}</p>{% endif %}
        {% if i.note %}<p><strong>{{ i.note }}</strong>{% if i.noteStatus == "בבדיקה" %} <small class="verify-badge">בבדיקה</small>{% endif %}</p>{% endif %}
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
