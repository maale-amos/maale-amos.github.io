{# Data-driven. Zero fabricated capacities. Source: sections.emergency. #}
<section class="section" id="emergency" data-extra="1" aria-labelledby="emergencyTitle">
  <div class="container">
    <div class="section-header fade-up">
      <h2 id="emergencyTitle"><i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i> {{ sections.emergency.title }}</h2>
      <div class="section-line"></div>
      <p>{{ sections.emergency.subtitle }}</p>
    </div>

    <div class="alert-box fade-up" role="status" style="margin-top:16px">
      <h3><i class="bi bi-broadcast" aria-hidden="true"></i> בזמן אזעקה</h3>
      <p>היכנסו למרחב מוגן תוך {{ sections.emergency.alertInstructions.enterTime }}. הישארו {{ sections.emergency.alertInstructions.stayTime }}.</p>
    </div>

    <h3 style="margin-top:24px">מקלטים</h3>
    <div class="shelter-grid fade-up">
      {%- for s in sections.emergency.shelters %}
      <div class="shelter-card">
        <h4><i class="bi bi-geo-alt-fill" aria-hidden="true"></i> {{ s.name }}</h4>
        <p>{{ s.location }}{% if s.note %}. {{ s.note }}{% endif %}</p>
        {% if s.accessibility %}<small>{{ s.accessibility }}</small>{% endif %}
      </div>
      {%- endfor %}
    </div>
    <p style="margin-top:12px"><small class="verify-badge">קיבולות המקלטים טרם פורסמו</small></p>

    <h3 style="margin-top:24px">קווי חירום</h3>
    <ul class="phone-list">
      {%- for line in sections.emergency.emergencyLines %}
      <li><strong>{{ line.name }}:</strong> <a href="tel:{{ line.phone }}">{{ line.phone }}</a>{% if line.note %} ({{ line.note }}){% endif %}</li>
      {%- endfor %}
    </ul>
  </div>
</section>
