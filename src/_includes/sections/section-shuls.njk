{# Data-driven. Times marked בבדיקה until verified. Source: sections.shuls. #}
<section class="section" id="shuls" data-extra="1" aria-labelledby="shulsTitle">
  <div class="container">
    <div class="section-header fade-up">
      <h2 id="shulsTitle"><i class="bi bi-book" aria-hidden="true"></i> {{ sections.shuls.title }}</h2>
      <div class="section-line"></div>
      <p>{{ sections.shuls.subtitle }}</p>
    </div>
    <div class="edu-cards fade-up">
      {%- for s in sections.shuls.items %}
      <div class="edu-card" style="border-right-color:{{ s.borderColor }}">
        <i class="bi {{ s.icon }}" style="color:{{ s.iconColor }}" aria-hidden="true"></i>
        <h4>{{ s.name }}</h4>
        <p><strong>נוסח:</strong> {{ s.nosach }}</p>
        {%- if s.times %}
          <p><strong>שחרית:</strong> {{ s.times.shacharit }}</p>
          <p><strong>מנחה:</strong> {{ s.times.mincha }}</p>
          <p><strong>ערבית:</strong> {{ s.times.maariv }}</p>
          {%- if s.timesStatus == "בבדיקה" %}
          <p><small class="verify-badge">זמנים בבדיקה</small></p>
          {%- endif %}
        {%- endif %}
        {%- if s.email %}<p style="font-size:0.8rem;color:var(--text-light)">{{ s.email }}</p>{%- endif %}
        {%- if s.location %}<p style="font-size:0.8rem;color:var(--text-light)">{{ s.location }}</p>{%- endif %}
        {%- if s.note %}<p>{{ s.note }}</p>{%- endif %}
        {%- if s.notice %}<p style="font-size:0.8rem;color:var(--text-light)">{{ s.notice }}</p>{%- endif %}
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
