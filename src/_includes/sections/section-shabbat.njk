<section class="section" id="shabbat" data-extra="1">
  <div class="container">
    <div class="section-header fade-up">
      <h2><i class="bi bi-brightness-high"></i> זמני שבת</h2>
      <div class="section-line"></div>
    </div>
    <div class="fade-up" style="max-width:500px;margin:0 auto;background:#fff;border-radius:var(--radius);box-shadow:var(--card-shadow);padding:30px;text-align:center">
      <h4 id="shabbatParasha" style="font-weight:800;color:var(--primary);margin-bottom:16px"></h4>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        <div style="background:var(--sky);border-radius:12px;padding:16px">
          <i class="bi bi-sunset" style="font-size:1.8rem;color:var(--accent)"></i>
          <div style="font-weight:700;margin-top:6px">הדלקת נרות</div>
          <div id="candleLighting" style="font-size:1.5rem;font-weight:900;color:var(--primary)"></div>
        </div>
        <div style="background:var(--sky);border-radius:12px;padding:16px">
          <i class="bi bi-stars" style="font-size:1.8rem;color:var(--accent)"></i>
          <div style="font-weight:700;margin-top:6px">צאת שבת</div>
          <div id="shabbatEnd" style="font-size:1.5rem;font-weight:900;color:var(--primary)"></div>
        </div>
      </div>
      <p style="font-size:0.78rem;color:var(--text-light);margin-top:12px"><i class="bi bi-geo-alt"></i> זמנים מחושבים אוטומטית מ־Hebcal לפי מיקום הישוב (מתעדכן כל שבוע)</p>
    </div>
  </div>
</section>