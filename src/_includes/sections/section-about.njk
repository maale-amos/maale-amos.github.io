{# Data-driven — mirrors pages/about.njk. No hardcoded 725/175+/1,592/founders. #}
<section class="section" id="about" data-extra="1">
  <div class="container">
    <div class="section-header fade-up">
      <h2><i class="bi bi-info-circle"></i> {{ sections.about.title }}</h2>
      <div class="section-line"></div>
    </div>
    <div class="about-grid fade-up">
      <div class="about-text">
        <h3>{{ sections.about.subtitle }}</h3>
        {% for p in sections.about.paragraphs %}
          <p>{{ p }}</p>
        {% endfor %}
        <div class="about-stats">
          {% for s in sections.about.stats %}
          <div class="stat-box">
            <div class="num">{{ s.num }}</div>
            <div class="label">{{ s.label }}</div>
          </div>
          {% endfor %}
        </div>
      </div>
      <div class="about-visual" style="background-image:url('/images/drone_view_1.jpg')">
        <div class="about-visual-overlay"></div>
      </div>
    </div>
    <div class="map-container fade-up">
      <iframe src="{{ sections.about.mapUrl | safeUrl }}" allowfullscreen loading="lazy" title="מפת מעלה עמוס" aria-label="מפת המיקום של מעלה עמוס" sandbox="allow-scripts allow-same-origin allow-popups" referrerpolicy="no-referrer"></iframe>
    </div>
  </div>
</section>
